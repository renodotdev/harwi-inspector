# Copy to .env.local and fill in from Supabase → Project Settings → API.
# .env.local is gitignored; never commit real keys.

# Project URL, e.g. https://abcdefghijklm.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# The service_role key. SERVER ONLY — it bypasses Row Level Security.
# It is read exclusively by Server Actions and Server Components, and must
# never be prefixed with NEXT_PUBLIC_ or referenced from a Client Component.
SUPABASE_SERVICE_ROLE_KEY=
